# We will compute class weights based on the counts of images in each class in the training dataset to address any class imbalance issues during model training. 
# The class weights will be calculated using the formula: weight = total_images / (num_classes * count_of_images_in_class), 
# which will give higher weights to underrepresented classes and help the model learn better from those classes during training.
def compute_class_weights(counts, class_names):
    total = sum(counts.values())
    n = len(class_names)
    weights = {}
    for i, cls in enumerate(class_names):
        weights[i] = total / (n * counts[cls])
    return weights

# We will compute class weights based on the counts of images in each class in the training dataset to address any class imbalance issues during model training. 
# The class weights will be calculated using the formula: weight = total_images / (num_classes * count_of_images_in_class), which will give higher weights to underrepresented classes and help the model learn better from those classes during training.
class_weights = compute_class_weights(train_counts, class_names)
