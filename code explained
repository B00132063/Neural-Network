# We will define a data augmentation pipeline using keras.Sequential to apply random transformations to the training images, such as horizontal flipping, random rotation, random zoom, and random contrast adjustments. This will help improve the model's generalization by introducing variability in the training data. We will then prepare the data pipelines for training, validation, and testing by caching, shuffling (for training), and prefetching the datasets for optimal performance during model training and evaluation.
augmentation = keras.Sequential([
    # We will define a data augmentation pipeline using keras.Sequential to apply random transformations to the training images, such as horizontal flipping, random rotation, random zoom, and random contrast adjustments. This will help improve the model's generalization by introducing variability in the training data. We will then prepare the data pipelines for training, validation, and testing by caching, shuffling (for training), and prefetching the datasets for optimal performance during model training and evaluation.
    layers.RandomFlip("horizontal"),
    layers.RandomRotation(0.05),
    layers.RandomZoom(0.1),
    layers.RandomContrast(0.1),
], name="augmentation")

train_ds = train_ds.cache().shuffle(1000).prefetch(AUTOTUNE)
val_ds = val_ds.cache().prefetch(AUTOTUNE)
