# Function to count images in each class for a given directory
def count_images_by_class(directory):
    counts = {}
    # We will sort the class names to ensure consistent order
    for class_name in sorted(os.listdir(directory)):
        # We will check if the path is a directory to avoid counting any non-directory files
        class_path = os.path.join(directory, class_name)
        # We will count only image files with common extensions
        if os.path.isdir(class_path):
            image_count = len([
                # We will check for common image file extensions to count only valid images
                f for f in os.listdir(class_path)
                # We will check for common image file extensions to count only valid images
                if f.lower().endswith((".jpeg", ".jpg", ".png"))
            ])
            # We will store the count in the dictionary with the class name as the key
            counts[class_name] = image_count
            # We will print the count for each class for debugging purposes
    return counts

# Function to print class distribution in a readable format
def print_distribution(name, counts):
    # We will calculate the total number of images across all classes to compute percentages
    total = sum(counts.values())
    # We will print the distribution of images for each class along with the percentage of the total
    print(f"\n{name} distribution:")
    # We will sort the classes by name to ensure consistent output
    for cls, count in counts.items():
        # We will calculate the percentage of images for this class relative to the total number of images
        pct = (count / total) * 100
        # We will print the class name, count, and percentage in a formatted string for readability
        print(f"{cls}: {count} images ({pct:.2f}%)")
        # We will print the total number of images at the end for reference
    print("Total:", total)

