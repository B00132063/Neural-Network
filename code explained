print("11. Building model")

# We will build a convolutional neural network model using the EfficientNetB0 architecture as the base model for feature extraction. 
# We will add a data augmentation layer at the input, followed by the EfficientNetB0 base model with pretrained ImageNet weights. 
# We will freeze the base model layers to prevent them from being updated during training. After the base model, we will add global average pooling, batch normalization, dropout, and dense layers to create the final classification head. The output layer will have a softmax activation function for multi-class classification. Finally, we will compile the model with an appropriate optimizer, loss function, and evaluation metrics.
inputs = keras.Input(shape=(IMG_SIZE, IMG_SIZE, 3))
x = augmentation(inputs)

# We will build a convolutional neural network model using the EfficientNetB0 architecture as the base model for feature extraction. 
# We will add a data augmentation layer at the input, followed by the EfficientNetB0 base model with pretrained ImageNet weights. 
# We will freeze the base model layers to prevent them from being updated during training. After the base model, we will add global average pooling, batch normalization, dropout, and dense layers to create the final classification head. The output layer will have a softmax activation function for multi-class classification. Finally, we will compile the model with an appropriate optimizer, loss function, and evaluation metrics.
base_model = keras.applications.EfficientNetB0(
    include_top=False,
    weights="imagenet",
    input_shape=(IMG_SIZE, IMG_SIZE, 3)
)

# We will build a convolutional neural network model using the EfficientNetB0 architecture as the base model for feature extraction.
base_model.trainable = False

x = keras.applications.efficientnet.preprocess_input(x)
x = base_model(x, training=False)
x = layers.GlobalAveragePooling2D()(x)
x = layers.BatchNormalization()(x)
x = layers.Dropout(0.35)(x)
x = layers.Dense(128, activation="relu")(x)
x = layers.Dropout(0.25)(x)
outputs = layers.Dense(num_classes, activation="softmax")(x)

model = keras.Model(inputs, outputs)

model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=LEARNING_RATE),
    loss="sparse_categorical_crossentropy",
    metrics=["accuracy"]
)

print("12. Model built")
model.summary()

# We will define callbacks for early stopping and model checkpointing to monitor the validation loss during training. 
# The EarlyStopping callback will stop training if the validation loss does not improve for 3 consecutive epochs and will restore the best weights. 
# The ModelCheckpoint callback will save the best model based on the lowest validation loss during training. 
# These callbacks will help us prevent overfitting and ensure that we save the best performing model for later evaluation and inference.
callbacks = [
    keras.callbacks.EarlyStopping(
        monitor="val_loss",
        patience=3,
        restore_best_weights=True
    ),
    keras.callbacks.ModelCheckpoint(
        "best_model.keras",
        monitor="val_loss",
        save_best_only=True
    )
]

print("13. Starting training")

# We will start the training process by calling the fit method on the model with the training dataset, validation dataset, number of epochs, class weights, and callbacks.
# We will also measure the training time by recording the start and end times around the fit method
start_time = time.time()

history = model.fit(
    train_ds,
    validation_data=val_ds,
    epochs=EPOCHS,
    class_weight=class_weights,
    callbacks=callbacks
)

end_time = time.time()
training_time = end_time - start_time

print("14. Training finished")
print("Training time (seconds):", training_time)
print("Training time (minutes):", training_time / 60)

print("15. Evaluating on test set")
test_results = model.evaluate(test_ds)
print("Test results:", test_results)

print("16. Making predictions")
y_true = np.concatenate([y.numpy() for _, y in test_ds])
y_probs = model.predict(test_ds)
